# ManagersButler environment variables
# Copy this file to `.env` and fill in your values, or run `venue-match init`
# to have the CLI generate one for you.

# ----- Required for `discover` / `run` commands -----
# Google Places API key. Get one at:
#   https://console.cloud.google.com/apis/credentials
# You must also enable "Places API (New)" for your project:
#   https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_MAPS_API_KEY=

# ----- Optional: Ollama for LLM-based venue profiling -----
# Without Ollama running, `profile` and `rank` fall back to a heuristic.
# Install Ollama at https://ollama.ai then run:
#   ollama pull qwen3:14b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_PROFILE=qwen3:14b

# ----- Optional: override the scraper user-agent -----
# SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ManagersButler/0.3)
